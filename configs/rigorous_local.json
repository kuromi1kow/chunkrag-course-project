{
  "seeds": [13, 21, 34],
  "embedding_model": "sentence-transformers/all-MiniLM-L6-v2",
  "generator_model": "google/flan-t5-base",
  "device": "auto",
  "retrieval_top_k": 4,
  "max_new_tokens": 32,
  "embedding_batch_size": 32,
  "generation_max_input_tokens": 768,
  "run_parametric_baseline": true,
  "bootstrap_samples": 1000,
  "confidence_level": 0.95,
  "datasets": [
    {
      "name": "squad_v2",
      "split": "validation",
      "max_examples": 150,
      "candidate_pool_size": 900,
      "answerable_only": true
    },
    {
      "name": "hotpot_qa",
      "config": "distractor",
      "split": "validation",
      "max_examples": 75
    }
  ],
  "retrievers": [
    {
      "name": "dense",
      "type": "dense"
    },
    {
      "name": "bm25",
      "type": "bm25"
    },
    {
      "name": "hybrid",
      "type": "hybrid",
      "candidate_pool_size": 20,
      "dense_weight": 0.6,
      "sparse_weight": 0.4
    },
    {
      "name": "hybrid_rerank",
      "type": "rerank",
      "model_name": "cross-encoder/ms-marco-MiniLM-L-6-v2",
      "candidate_pool_size": 20,
      "batch_size": 16,
      "base_retriever": {
        "type": "hybrid",
        "candidate_pool_size": 20,
        "dense_weight": 0.6,
        "sparse_weight": 0.4
      }
    }
  ],
  "chunkers": [
    {
      "name": "fixed_128",
      "type": "fixed",
      "chunk_size": 128,
      "chunk_overlap": 19
    },
    {
      "name": "fixed_256",
      "type": "fixed",
      "chunk_size": 256,
      "chunk_overlap": 38
    },
    {
      "name": "recursive_256",
      "type": "recursive",
      "chunk_size": 256,
      "chunk_overlap": 38
    },
    {
      "name": "sentence_256",
      "type": "sentence",
      "chunk_size": 256
    },
    {
      "name": "semantic_256",
      "type": "semantic",
      "chunk_size": 256,
      "similarity_threshold": 0.72,
      "min_chunk_tokens": 96
    },
    {
      "name": "chonkie_recursive_256",
      "type": "chonkie_recursive",
      "chunk_size": 256
    }
  ]
}
